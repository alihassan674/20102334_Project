// ─────────────────────────────────────────────────────────────
// Lodgely — Prisma Schema
// Student Housing & Occupancy Intelligence Platform
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Hostel ───────────────────────────────────────────────────
model Hostel {
  id          String   @id @default(uuid())
  name        String   @unique
  totalFloors Int
  address     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms Room[]

  @@map("hostels")
}

// ── Room ─────────────────────────────────────────────────────
model Room {
  id           String     @id @default(uuid())
  roomNumber   String
  floor        Int
  capacity     Int
  occupants    Int        @default(0)
  type         RoomType   @default(SINGLE)
  pricePerMonth Float
  status       RoomStatus @default(AVAILABLE)
  hostelId     String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  hostel   Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([roomNumber, hostelId])
  @@map("rooms")
}

// ── Student ──────────────────────────────────────────────────
model Student {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  rollNumber  String   @unique
  phone       String
  checkInDate DateTime @default(now())
  roomId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("students")
}

// ── Enums ────────────────────────────────────────────────────
enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}
